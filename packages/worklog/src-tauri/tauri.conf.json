{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "worklog",
  "version": "1.2.14",
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDRTgyMzUwQTM4NTNGNTkKUldSWlA0V2pVQ1BvTE9lSlFzaGRWQ250M1I3MitvT1IzOW5GK0pxajg0TGtXRW9kTVdsWlZBSlkK",
      "endpoints": [
        "https://github.com/regisx001/Worklog/releases/latest/download/latest.json",
        "https://regisx001.github.io/Worklog/latest.json"
      ]
    }
  },
  "identifier": "com.regisx001.worklog",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Worklog",
