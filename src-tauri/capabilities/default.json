{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$DOCUMENT/.worklog"
        },
        {
          "path": "$HOME/.worklog"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$HOME/**/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$DOCUMENT/.worklog"
        },
        {
          "path": "$HOME/.worklog"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$HOME/**/*"
        }
      ]
    }
  ]
}